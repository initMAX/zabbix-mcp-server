# Ubuntu 24.04 — python3.12 is the system default
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y python3 python3-venv python3-pip && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY . /opt/src
WORKDIR /opt/src

# Dry-run should find python3.12
RUN chmod +x deploy/install.sh && \
    deploy/install.sh --dry-run 2>&1 | tee /tmp/output.log && \
    grep -qE "Using python3(\\.12| )" /tmp/output.log && echo "PASS: detected python3.12" || \
    (echo "FAIL: did not detect python3.12" && cat /tmp/output.log && exit 1)

# Full install
RUN deploy/install.sh install 2>&1 | tee /tmp/install.log && \
    /opt/zabbix-mcp/venv/bin/zabbix-mcp-server --version && \
    echo "PASS: full install succeeded"

# Test uninstall
RUN echo "yes" | deploy/install.sh uninstall 2>&1 | tee /tmp/uninstall.log && \
    ! test -d /opt/zabbix-mcp && \
    ! test -d /etc/zabbix-mcp && \
    ! test -d /var/log/zabbix-mcp && \
    ! id zabbix-mcp 2>/dev/null && \
    echo "PASS: uninstall removed everything"
