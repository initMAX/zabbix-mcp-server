# Fedora (latest) — always has a recent Python
FROM fedora:latest

RUN dnf install -y python3 python3-pip && dnf clean all

COPY . /opt/src
WORKDIR /opt/src

RUN chmod +x deploy/install.sh && \
    deploy/install.sh --dry-run 2>&1 | tee /tmp/output.log && \
    grep -qE "Using python3" /tmp/output.log && echo "PASS: detected python3" || \
    (echo "FAIL: did not detect python3" && cat /tmp/output.log && exit 1)

RUN deploy/install.sh install 2>&1 | tee /tmp/install.log && \
    /opt/zabbix-mcp/venv/bin/zabbix-mcp-server --version && \
    echo "PASS: full install succeeded"
